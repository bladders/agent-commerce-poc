# Agent Commerce POC — copy to .env and fill in your keys
# cp .env.example .env

# Required: Stripe test-mode secret key
# Dashboard → https://dashboard.stripe.com/test/apikeys → Standard keys → Secret key
# Must start with sk_test_ (restricted keys rk_test_ may lack permissions)
STRIPE_SECRET_KEY=sk_test_your_key_here

# Required: OpenAI API key
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here

# Optional: model override (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional: Stripe CLI webhook forwarding secret
# Run: stripe listen --forward-to localhost:8000/webhooks/stripe
# STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Optional: gate API endpoints behind a shared key
# POC_API_KEY=change-me
